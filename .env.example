# Embeddings (data/ingest.py, graph/store.py) — pinned to OpenAI text-embedding-3-small,
# not provider-swappable (ADR-006: a separate, narrower concern than the chat model).
OPENAI_API_KEY=

# Chat model (graph/llm.py) — provider/model picked via init_chat_model, not hardcoded
# (ADR-006). Uncomment one block below to swap providers.
# Only the API key for whichever provider you actually use is required.
CHAT_MODEL=claude-sonnet-4-6
CHAT_MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- OpenAI alternative ---
# CHAT_MODEL=gpt-5.4
# CHAT_MODEL_PROVIDER=openai
# (reuses OPENAI_API_KEY above)

# --- Groq alternative ---
# CHAT_MODEL=llama-3.3-70b-versatile
# CHAT_MODEL_PROVIDER=groq
# GROQ_API_KEY=
